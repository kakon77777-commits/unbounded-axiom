# local tooling (preview launch config etc.)
.claude/

# python bytecode
__pycache__/
*.pyc

# generated site output — Cloudflare Pages rebuilds it via `python3 build.py`
/dist/

# Astro human shell prototype (build artifacts)
/shell/node_modules/
/shell/dist/
/shell/.astro/

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example

# ingest workspace (staging only; canonical content lives in content/papers/)
ingest/01-before/*
!ingest/01-before/.gitkeep
ingest/02-agent-staging/*
!ingest/02-agent-staging/.gitkeep
ingest/03-after/*
!ingest/03-after/.gitkeep
ingest/reports/*
!ingest/reports/.gitkeep
# processed batches are moved here after publish (local record; canon is content/papers/)
ingest/_archive/
# held-back papers pending Neo's publish/skip decision
ingest/_hold/
# pre-id companion staging — Neo groups code/images by his own naming BEFORE the
# parent paper has an lm-id; sorted into content/attachments/{id}/ once it does.
ingest/attachments-pending/*
!ingest/attachments-pending/README.md
.spectral.env

# media source files (large; live in the Cloudflare R2 bucket `unboundedaxiom`)
studio/
