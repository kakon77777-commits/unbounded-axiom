---
import Base from '../../layouts/Base.astro';
import { getPapers, getRaw, extOf, getMedia, getCompanions } from '../../lib/engine';
import { marked } from '../../lib/md';
import { extractGeoSignals, geoJsonLdBlocks } from '../../lib/geo';
import 'katex/dist/katex.min.css';

export function getStaticPaths() {
  return getPapers().map((paper) => ({ params: { id: paper.id }, props: { paper } }));
}

const { paper } = Astro.props;
const media = getMedia()[paper.id];
const companions = getCompanions()[paper.id] || [];
const KIND_ICON: Record<string, string> = {
  examples: '🧩', code: '💻', proof: '∴', data: '📊', witness: '📊',
  verify: '✅', demo: '▶️', core: '🧠', dataset: '📊', notebook: '📓',
  image: '🖼️', figure: '🖼️',
};
const isImageKind = (kind: string) => kind === 'image' || kind === 'figure';
const fmtBytes = (b: number) =>
  b >= 1048576 ? `${(b / 1048576).toFixed(1)} MB`
  : b >= 1024 ? `${(b / 1024).toFixed(0)} KB` : `${b} B`;
const ext = extOf(paper);
const raw = getRaw(paper.raw_url);
const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const body =
  ext === 'md' ? (marked.parse(raw, { async: false }) as string) : `<pre><code>${esc(raw)}</code></pre>`;

const ORIGIN = 'https://logic.evemisslab.com';
const canonical = `${ORIGIN}${paper.canonical_url}`;
const MIME: Record<string, string> = {
  md: 'text/markdown', py: 'text/x-python', lean: 'text/x-lean', ts: 'text/typescript',
  jsx: 'text/jsx', tex: 'application/x-tex', ipynb: 'application/x-ipynb+json',
  pdf: 'application/pdf',
  docx: 'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
};
const mime = MIME[ext] || 'application/octet-stream';
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  name: paper.title,
  url: canonical,
  identifier: paper.id,
  inLanguage: paper.language,
  author: { '@type': 'Person', name: 'Neo.K (許筌崴)' },
  publisher: { '@type': 'Organization', name: 'EveMissLab / 一言諾科技有限公司' },
  isPartOf: { '@type': 'Collection', name: 'EVEMISSLAB Logic Matrix', url: ORIGIN },
  encodingFormat: 'text/html',
  ...(companions.length ? {
    hasPart: companions.map((c) => ({
      '@type': /^(py|ts|jsx|lean)$/.test(c.ext) ? 'SoftwareSourceCode' : 'CreativeWork',
      name: c.label,
      url: `${ORIGIN}${c.raw_url}`,
      encodingFormat: c.mime,
      ...(/^(py|ts|jsx)$/.test(c.ext) ? { programmingLanguage: c.ext } : {}),
    })),
  } : {}),
};
const geoBlocks = ext === 'md' ? geoJsonLdBlocks(extractGeoSignals(raw), canonical) : [];
---
<Base title={`${paper.title} · Logic Matrix`} description={`${paper.title} | EVEMISSLAB Logic Matrix`}>
  <Fragment slot="head">
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="ai-content-policy" content="indexable, citable, training-allowed" />
    <meta name="lm-paper-id" content={paper.id} />
    <meta name="author" content="Neo.K (許筌崴)" />
    <link rel="alternate" type={mime} href={paper.raw_url} title={`原始檔 / source (${ext})`} />
    <link rel="prefetch" href={`/api/log-crawler?id=${paper.id}`} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
    {geoBlocks.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </Fragment>

  <div class="reader">
    <div class="wrap">
      <a class="back" href="/timeline/">← Archive</a>
      <div class="reader-head measure">
        <div class="eyebrow">{paper.id}{paper.month ? ` · ${paper.month}` : ''}</div>
        <h1>{paper.title}</h1>
        <div class="reader-meta">
          <span>{paper.language} · {ext}</span>
          <a href={paper.raw_url} download={`${paper.title}.${ext}`}>Download ⬇</a>
          <a href={paper.raw_url}>Raw source ↗</a>
          <a href={paper.api_url}>Metadata ↗</a>
        </div>
      </div>
      {media && (media.audio || media.video) && (
        <div class="media measure" role="group" aria-label="本文影音 / Audio and video for this paper">
          {media.audio && (
            <div class="media-item">
              <div class="eyebrow">🎧 聆聽本文 · Listen{media.audio_kind === 'overview' ? ' · 對談概覽 audio overview' : ''}</div>
              <audio controls preload="none" src={media.audio} aria-label={`Audio overview of ${paper.title}`}>
                你的瀏覽器不支援音訊播放。<a href={media.audio}>下載音檔</a>
              </audio>
            </div>
          )}
          {media.video && (
            <div class="media-item">
              <div class="eyebrow">🎬 影片 · Video</div>
              <video controls preload="none" src={media.video} aria-label={`Video for ${paper.title}`}></video>
            </div>
          )}
        </div>
      )}
      {companions.length > 0 && (
        <div class="attachments measure" role="group" aria-label="本文附件 / Companion files for this paper">
          <div class="eyebrow">📎 附件 · Companion files — 隨文交付的程式 / 證明 / 資料，可獨立下載重驗</div>
          <ul class="attach-list">
            {companions.map((c) => (
              isImageKind(c.kind) ? (
                <li class="attach-item attach-item--image">
                  <a href={c.raw_url} target="_blank" rel="noopener">
                    <img class="attach-image" src={c.raw_url} alt={c.label} loading="lazy" />
                  </a>
                  <span class="attach-caption">{KIND_ICON[c.kind] || '🖼️'} {c.label} <span class="attach-meta">({c.ext} · {fmtBytes(c.bytes)})</span></span>
                </li>
              ) : (
                <li class="attach-item">
                  <span class="attach-kind" aria-hidden="true">{KIND_ICON[c.kind] || '📎'}</span>
                  <a class="attach-link" href={c.raw_url} download={c.orig}>{c.label}</a>
                  <span class="attach-meta">{c.ext} · {fmtBytes(c.bytes)}</span>
                </li>
              )
            ))}
          </ul>
        </div>
      )}
      <article class="prose" set:html={body}></article>
    </div>
  </div>
  <style>
    .media { margin: 1.6rem 0 0.5rem; display: flex; flex-direction: column; gap: 1.1rem; }
    .media-item { display: flex; flex-direction: column; gap: 0.5rem; padding: 1rem 1.1rem; border: 1px solid var(--line); border-radius: 0.6rem; background: var(--surface); }
    .media-item audio { width: 100%; }
    .media-item video { width: 100%; max-height: 60vh; border-radius: 0.4rem; background: #000; }
    .attachments { margin: 1.6rem 0 0.5rem; padding: 1rem 1.1rem; border: 1px solid var(--line); border-radius: 0.6rem; background: var(--surface); }
    .attach-list { list-style: none; margin: 0.75rem 0 0; padding: 0; display: flex; flex-direction: column; gap: 0.55rem; }
    .attach-item { display: flex; align-items: baseline; gap: 0.6rem; }
    .attach-kind { flex: none; }
    .attach-link { font-weight: 600; text-decoration: none; border-bottom: 1px solid currentColor; }
    .attach-link:hover { opacity: 0.72; }
    .attach-meta { margin-left: auto; font-size: 0.8rem; opacity: 0.6; white-space: nowrap; font-variant-numeric: tabular-nums; }
    .attach-item--image { flex-direction: column; align-items: flex-start; gap: 0.45rem; }
    .attach-image { display: block; max-width: 100%; max-height: 32rem; border-radius: 0.4rem; border: 1px solid var(--line); }
    .attach-item--image .attach-caption { font-size: 0.88rem; opacity: 0.85; }
    .attach-item--image .attach-meta { margin-left: 0.3rem; opacity: 0.55; }
  </style>
</Base>
