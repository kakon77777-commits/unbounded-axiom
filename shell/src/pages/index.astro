---
import Base from '../layouts/Base.astro';
import { getPapers, getCorpus, getTimeline } from '../lib/engine';

const corpus = getCorpus();
const timeline = getTimeline();
const papers = getPapers();

// Rotating random sample. An AI agent (or human) seeding ideas from the homepage
// should not keep landing on the same handful of papers — the old fixed "latest
// month, first by id" slice biased every visitor toward the alphabetically-first
// filenames. The pool is the whole corpus and the set re-rolls each build/deploy;
// the complete list lives at /timeline/. (AI reads the static HTML, so this must be
// server-side — a build-time shuffle, not client JS.)
function sample(arr, n) {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a.slice(0, n);
}
const featured = sample(papers, 12);

const collab = corpus.authorship?.['collaborative'] ?? 0;
const aiAuto = corpus.authorship?.['ai_autonomous'] ?? 0;
const monthCount = timeline.reduce((a, y) => a + y.months.length, 0);
---
<Base title="Logic Matrix — EveMissLab Theoretical Corpus">
  <header class="hero">
    <div class="wrap">
      <div class="eyebrow">EveMissLab · Machine-readable corpus</div>
      <h1>A theoretical corpus, read by minds and machines alike.</h1>
      <p class="lede">
        {corpus.count} papers spanning mathematics, logic, AI architecture, physics,
        political economy and cognition — each with a permanent identity and a single
        canonical route.
      </p>
      <div class="stats">
        <div class="stat"><div class="n">{corpus.count}</div><div class="l">Papers</div></div>
        <div class="stat"><div class="n">{collab}</div><div class="l">人機協力</div></div>
        <div class="stat"><div class="n">{aiAuto}</div><div class="l">AI 自主</div></div>
        <div class="stat"><div class="n">{monthCount}</div><div class="l">Months</div></div>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="wrap">
      <h2>Browse by time</h2>
      <div class="years">
        {timeline.map((y) => (
          <div class="year-row">
            <div class="year-h"><span class="y">{y.year}</span><span class="eyebrow">{y.count} papers</span></div>
            <div class="months">
              {y.months.map((m) => (
                <a class="month-pill" href={`/timeline/#${m.month}`}><span>{m.month}</span><span class="c">{m.count}</span></a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <h2>探索切片 · A rotating sample</h2>
      <p class="sample-note">每次重建隨機抽選，不代表全部；完整語料庫見時間軸。 A random draw from the whole corpus — it re-rolls on every deploy, so this is a doorway, not the collection.</p>
      <div class="papers">
        {featured.map((p) => (
          <a class="paper-row" href={`/p/${p.id}/`}>
            <span class="pid">{p.id}</span>
            <span class="pt">{p.title}</span>
            <span class="pmeta">{p.language} · {p.month}</span>
          </a>
        ))}
      </div>
      <p style="margin-top:1.8rem"><a href="/timeline/">View the full chronological archive · 全部 {corpus.count} 篇 →</a></p>
    </div>
  </section>
</Base>

<style>
  .sample-note { margin: -0.6rem 0 1.6rem; max-width: var(--measure); font-size: 0.82rem; line-height: 1.6; color: var(--paper-faint); }
</style>
