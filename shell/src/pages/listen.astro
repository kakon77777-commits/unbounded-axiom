---
import Base from '../layouts/Base.astro';
import { getMedia, getFeaturedMedia, getPapers } from '../lib/engine';

const media = getMedia();
const featured = getFeaturedMedia();
const papers = getPapers();
const byId: Record<string, any> = Object.fromEntries(papers.map((p) => [p.id, p]));
const withAudio = Object.entries(media).filter(([id, m]) => m.audio && byId[id]);
const withVideo = Object.entries(media).filter(([id, m]) => m.video && byId[id]);
const fA = featured?.audio ? 1 : 0;
const fV = featured?.video ? 1 : 0;
const audioCount = withAudio.length + fA;
const videoCount = withVideo.length + fV;
const total = new Set([...withAudio, ...withVideo].map(([id]) => id)).size + (featured && (featured.audio || featured.video) ? 1 : 0);
---
<Base title="影音 · Listen — Logic Matrix">
  <header class="hero">
    <div class="wrap">
      <div class="eyebrow">Audio · Video · Accessibility</div>
      <h1>Listen to the corpus.</h1>
      <p class="lede">
        論文也能被「聽」與「看」。<b>音頻</b>是對談式概覽（deep-dive）—— 無障礙專區，講概念、不逐字念公式，
        因此能優雅處理大量數學；<b>影片</b>是 explainer。每支都掛在論文的永久 id 上、由 <code>/media/*</code> 提供。
      </p>
      <div class="stats">
        <div class="stat"><div class="n">{total}</div><div class="l">有影音</div></div>
        <div class="stat"><div class="n">{audioCount}</div><div class="l">🎧 音頻</div></div>
        <div class="stat"><div class="n">{videoCount}</div><div class="l">🎬 影片</div></div>
      </div>
    </div>
  </header>

  {featured && (featured.audio || featured.video) && (
    <section class="section">
      <div class="wrap">
        <div class="eyebrow">✦ 關於語料庫 · About the corpus</div>
        <div class="featured">
          {featured.audio && (
            <div class="fcard">
              <div class="ftitle">🎧 {featured.audio_title}</div>
              <audio controls preload="none" src={featured.audio} aria-label={featured.audio_title}></audio>
            </div>
          )}
          {featured.video && (
            <div class="fcard">
              <div class="ftitle">🎬 {featured.video_title}</div>
              <video controls preload="metadata" src={featured.video} aria-label={featured.video_title}></video>
            </div>
          )}
        </div>
        <p class="note">{featured.desc_zh}<br /><span style="opacity:.65">{featured.desc_en}</span></p>
      </div>
    </section>
  )}

  <section class="section">
    <div class="wrap">
      <div class="eyebrow">🎧 音頻 · 無障礙</div>
      <h2>Audio · accessible listening</h2>
      <p class="note">
        給看不到的人，也給想用聽的人。點進論文頁即有無障礙播放器（鍵盤可操作、ARIA 標記）。
      </p>
      {withAudio.length === 0 ? (
        <p class="note seed">尚無音頻 —— 影音生態剛起步。等 NotebookLM 概覽上架、R2 就緒，這裡就會長出可聽的論文。</p>
      ) : (
        <div class="papers">
          {withAudio.map(([id, m]) => (
            <a class="paper-row" href={`/p/${id}/`}>
              <span class="pid">{id}</span>
              <span class="pt">{m.audio_title || byId[id].title}</span>
              <span class="pmeta">🎧 對談概覽 · listen</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="eyebrow">🎬 影片</div>
      <h2>Video · explainers</h2>
      <p class="note">先放這裡當櫥窗；英文預印本完成後再轉載到影音平台。</p>
      {withVideo.length === 0 ? (
        <p class="note seed">尚無影片。</p>
      ) : (
        <div class="papers">
          {withVideo.map(([id, m]) => (
            <a class="paper-row" href={`/p/${id}/`}>
              <span class="pid">{id}</span>
              <span class="pt">{byId[id].title}</span>
              <span class="pmeta">🎬 video</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <style>
    .featured { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.2rem; margin: 1.4rem 0 0.4rem; }
    .fcard { border: 1px solid var(--line); border-radius: 0.7rem; background: var(--surface); padding: 1.1rem 1.2rem; display: flex; flex-direction: column; gap: 0.7rem; }
    .ftitle { font-weight: 600; font-size: 0.98rem; }
    .fcard audio { width: 100%; }
    .fcard video { width: 100%; max-height: 60vh; border-radius: 0.4rem; background: #000; }
    .note { color: var(--paper-dim); max-width: var(--measure); line-height: 1.75; margin-top: 0.6rem; }
    .note code { font-family: var(--mono); font-size: 0.82em; color: var(--teal); }
    .note.seed { padding: 1.2rem 1.4rem; border: 1px dashed var(--line-strong); border-radius: 0.6rem; margin-top: 1.2rem; }
  </style>
</Base>
